{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rietveld-next.org/schema/golden_dataset.schema.json",
  "title": "RietveldNextGoldenDataset",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "domain",
    "description",
    "axis_units",
    "intensity_units",
    "x",
    "y",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "golden-dataset-v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$"
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "axis_units": {
      "type": "string",
      "minLength": 1
    },
    "intensity_units": {
      "type": "string",
      "minLength": 1
    },
    "x": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 1
    },
    "y": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 1
    },
    "provenance": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
