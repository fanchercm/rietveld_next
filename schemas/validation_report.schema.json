{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rietveld-next.org/schema/validation_report.schema.json",
  "title": "RietveldNextValidationReport",
  "type": "object",
  "required": [
    "schema_version",
    "generated_by",
    "passed",
    "summary",
    "cases",
    "known_limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "validation-report-v1"
    },
    "generated_by": {
      "type": "string",
      "minLength": 1
    },
    "passed": {
      "type": "boolean"
    },
    "summary": {
      "type": "object",
      "required": [
        "total",
        "passed",
        "failed",
        "expensive"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "expensive": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "known_limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
